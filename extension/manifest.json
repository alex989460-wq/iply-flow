{
  "manifest_version": 3,
  "name": "SuperGestor Panel Auto-Renew",
  "version": "1.7.0",
  "description": "Renova clientes P2Cine e Uniplay usando a sessao real logada. Auto-abre painel, indicador de status e alerta de logout.",
  "permissions": ["storage", "alarms", "notifications", "tabs", "scripting"],
  "host_permissions": [
    "https://daily3.news/*",
    "https://*.daily3.news/*",
    "https://searchdefense.top/*",
    "http://searchdefense.top/*",
    "https://gesapioffice.com/*",
    "https://supergestor.top/*",
    "https://fphqfgxfeaylldpxjqan.supabase.co/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_title": "SuperGestor Auto-Renew" },
  "icons": { "128": "icon.png" }
}
